{
  "name": "noren-extension",
  "private": true,
  "version": "1.0.0",
  "description": "Noren Chrome extension. Voice-matched AI writing in any text field.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/usenoren/noren-extension.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "package": "npm run build && rm -f noren-extension-v$npm_package_version.zip && cd dist && zip -r ../noren-extension-v$npm_package_version.zip .",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "dompurify": "^3.3.1",
    "marked": "^17.0.3"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.30",
    "@sveltejs/vite-plugin-svelte": "^5",
    "@tailwindcss/vite": "^4",
    "@types/chrome": "^0.0.300",
    "@types/dompurify": "^3.0.5",
    "svelte": "^5",
    "svelte-check": "^4",
    "tailwindcss": "^4",
    "typescript": "^5.7",
    "vite": "^6"
  }
}
